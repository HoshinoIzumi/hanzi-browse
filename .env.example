# ─── Local Development ───────────────────────────────
# Copy this file to .env and fill in values.
# `make dev` loads .env automatically.
#
# Only DATABASE_URL is required. Everything else is optional —
# the server starts without Vertex, Stripe, or Google OAuth.

# Postgres (local Docker — matches docker-compose.yml defaults)
DATABASE_URL=postgresql://hanzi:hanzi_dev@localhost:5433/hanzi

# Better Auth (required for dashboard sign-in)
BETTER_AUTH_SECRET=dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3456

# ─── Optional ────────────────────────────────────────

# Google OAuth (for "Sign in with Google" on dashboard)
# Create at https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3456/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Stripe (for credit purchase flow)
# STRIPE_SECRET_KEY=sk_live_or_sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CREDIT_PRICE_ID=price_...
# STRIPE_CREDIT_PACK_1=100:price_...
# STRIPE_CREDIT_PACK_2=500:price_...
# STRIPE_CREDIT_PACK_3=1500:price_...

# Vertex AI (for managed task execution)
# Without this, the server runs fine but managed tasks won't execute.
# VERTEX_SA_PATH=../vertex-sa.json
